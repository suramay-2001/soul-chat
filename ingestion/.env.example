# Copy to .env.local and fill in secrets (see README).
# Never commit .env.local.

# Use the exact URI from Supabase Dashboard → Connect (session/transaction pooler if you need IPv4).
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
OPENAI_API_KEY=

S3_BUCKET=maa-aap-bucket
S3_BOOKS_PREFIX=books/
# Region where the S3 bucket lives (must match the bucket).
AWS_REGION=us-east-1

# If anonymous ListBucket is denied, list keys in a file (one per line) and set:
# S3_KEY_LIST_FILE=books_keys.txt
# Set to 1 for unsigned requests (public object reads; often used with S3_KEY_LIST_FILE).
# S3_ANONYMOUS=1

# Required for private buckets unless ~/.aws is configured (see README).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=   # only if using temporary credentials (SSO, assumed role)

OPENAI_EMBED_MODEL=text-embedding-3-large
CHUNK_TARGET_TOKENS=650
CHUNK_OVERLAP_TOKENS=120
INGEST_TMP_DIR=.tmp/maa-books

# OCR (Tesseract): PDF_OCR_MODE=always | auto | never
# PDF_OCR_MIN_CHARS=40
# OCR_DPI=200
# OCR_LANG=eng
# OCR_PSM=6
# OCR_OEM=3
# OCR_TIMEOUT=0
# OCR_MAX_IMAGE_DIM=4000
# If `tesseract` is not on PATH: TESSERACT_CMD=/opt/homebrew/bin/tesseract
# TESSERACT_CMD=
