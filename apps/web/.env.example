# ── Required secrets (set in Vercel dashboard or .env.local) ──
# NEVER commit real values. Use .env.local locally (gitignored).
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o
OPENAI_EMBED_MODEL=text-embedding-3-large

# Supabase session-mode pooler URL
# Format: postgresql://postgres.<ref>:<password>@<host>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=postgresql://REPLACE_ME

# Rate limit (requests per IP per minute)
RATE_LIMIT_RPM=100

# Global OpenAI API rate limit (all users combined, per minute — cost protection)
OPENAI_RATE_LIMIT_RPM=100
